.env
.env.*
!.env.example
config/secret.key

# ════════════════════════════════════════════════════════════════
# Runtime / user data (may contain PII, password hashes, prompts)
# ════════════════════════════════════════════════════════════════
data/
notes.db
embeddings/

# Uploaded raw materials
raw/

# Legacy data dirs (pre-wiki/ migration)
cases/
persons/
locations/
laws/
images/
!docs/images/

# Generated wiki content (user knowledge base) - keep templates only
wiki/*
!wiki/templates/
!wiki/templates/**
!wiki/.gitkeep

# ════════════════════════════════════════════════════════════════
# Logs
# ════════════════════════════════════════════════════════════════
mjq.log
mjq.log.*
*.pid
flask-backend.*.log
server.*.log
server.vite.*.log
server.output
nohup.out

# ════════════════════════════════════════════════════════════════
# Python
# ════════════════════════════════════════════════════════════════
__pycache__/
/.test-tmp/
/test-tmp/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
build/
dist/

# ════════════════════════════════════════════════════════════════
# Node / frontend build artifacts
# ════════════════════════════════════════════════════════════════
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/*.log
frontend/.eslintcache
frontend/coverage/
node_modules/
*.tsbuildinfo

# ════════════════════════════════════════════════════════════════
