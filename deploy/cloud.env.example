# mjq-cloud 服务端环境变量（systemd EnvironmentFile）
# 部署到服务器后复制为 /opt/mjq-handynotes/cloud.env，按实际值填写。
#
# 安全：本文件包含密钥。chmod 600 + chown root:root 后 systemd 仍能读
# （EnvironmentFile 由 root 进程读取，再 setuid 给 User）。

# ─── 监听 ───────────────────────────────────────────
MJQ_CLOUD_HOST=127.0.0.1
MJQ_CLOUD_PORT=5005
# 之所以 bind 127.0.0.1：Nginx 反向代理到 5005，云端不直接对外。
# 如果不上 Nginx（开发期临时验证），可改 0.0.0.0。

# ─── JWT 共享密钥 ───────────────────────────────────
# 必须与本机 agent 配置同一份。生产建议用 openssl rand -hex 32 生成。
# 不设的话 cloud 会自动写到 <project>/config/jwt.secret，但分布式部署应该显式指定。
MJQ_JWT_SECRET=PASTE_64_HEX_CHARS_HERE

# ─── CORS 白名单 ────────────────────────────────────
# 同源（Nginx 同时托管前端和反向代理 cloud）的话理论上不需要 CORS；
# 但开发期前端 dev server（5174）跨域调云端时仍需放行。
# 多个用逗号分隔；生产改成 https://your-domain
MJQ_CLOUD_CORS_ORIGINS=http://YOUR_SERVER_IP,http://localhost:5174

# ─── 可选：Schema 合成 LLM ─────────────────────────
# 不设则 schema synth 走 mock（规则化目录名）。配置后走真 LLM。
# MJQ_CLOUD_LLM_API_KEY=sk-xxxxxx
# MJQ_CLOUD_LLM_BASE_URL=https://api.deepseek.com/v1
# MJQ_CLOUD_LLM_MODEL=deepseek-chat

# ─── 调试 ───────────────────────────────────────────
MJQ_CLOUD_DEBUG=false
