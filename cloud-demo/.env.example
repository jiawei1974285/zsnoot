# 复制本文件为 .env 后填入真实值。.env 不会被提交到 git。
#
# 文本模型（必填）
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
LLM_PROVIDER=openai

# 视觉模型（可选，留空则跟随文本模型）
VISION_MODEL_API_KEY=
VISION_MODEL_BASE_URL=
VISION_MODEL_MODEL=
VISION_MODEL_PROVIDER=

# OCR 模型（可选，留空则跟随文本模型）
OCR_MODEL_API_KEY=
OCR_MODEL_BASE_URL=
OCR_MODEL_MODEL=
OCR_MODEL_PROVIDER=
